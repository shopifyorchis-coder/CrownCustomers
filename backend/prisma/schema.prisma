generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ShopSettings {
  id             Int      @id @default(autoincrement())
  shop           String   @unique @default("demo-shop.myshopify.com")
  enabled        Boolean  @default(false)
  discountValue  Int      @default(15)
  discountType   String   @default("percentage")
  couponDays     Int      @default(30)
  emailSubject   String   @default("You are one of our Crown Customers!")
  introText      String   @default("As a thank you for your loyalty, here is a personal reward.")
  cooldownDays   Int      @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CustomerScore {
  id            Int      @id @default(autoincrement())
  shop          String   @default("demo-shop.myshopify.com")
  customerId    String
  shopifyCustomerId String?
  name          String
  email         String
  totalSpent    Float    @default(0)
  ordersCount   Int      @default(0)
  lastOrderDate DateTime @default(now())
  rfmScore      Int      @default(0)
  segment       String   @default("Regular Customer")
  isTop         Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  rewardCoupons RewardCoupon[]

  @@unique([shop, customerId])
  @@index([shop, rfmScore])
}

model SyncState {
  id                Int      @id @default(autoincrement())
  shop              String   @unique
  lastSyncAt        DateTime?
  customersImported Int      @default(0)
  ordersImported    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  status    String
  customer  String
  message   String
  createdAt DateTime @default(now())
}

model RewardCoupon {
  id                Int           @id @default(autoincrement())
  shop              String
  customerScoreId   Int
  customerId        String
  customerEmail     String
  customerName      String
  discountCode      String?
  discountType      String
  discountValue     Float
  startsAt          DateTime
  endsAt            DateTime
  shopifyDiscountId String?
  status            String
  errorMessage      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  customerScore     CustomerScore @relation(fields: [customerScoreId], references: [id], onDelete: Cascade)

  @@index([shop, customerId, createdAt])
  @@index([shop, status, createdAt])
}
